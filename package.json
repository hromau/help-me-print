{
  "name": "duplexprint",
  "version": "0.1.0",
  "description": "Cross-platform manual duplex printing assistant.",
  "main": "dist-electron/electron/main.js",
  "author": "Easure",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "concurrently \"vite --host localhost\" \"wait-on http://localhost:5173 && ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "api:test": "npm --prefix api test",
    "cpp:configure": "cmake -S . -B build",
    "cpp:build": "cmake --build build",
    "cpp:test": "ctest --test-dir build --output-on-failure",
    "start": "electron .",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  }
}
